TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Generated automatically by `python setup_totp.py` — do not set this by hand.
TOTP_SECRET=

PORT=8000

# Used by the Streamlit app to reach the FastAPI backend
API_BASE_URL=http://localhost:8000

# Redis is used for session storage, contacts caching, and as the Celery
# broker/result backend. Local (non-Docker) dev: run a Redis container or
# `redis-server` and point this at it. Docker Compose overrides this to
# redis://redis:6379/0 automatically.
REDIS_URL=redis://localhost:6379/0

# SQL Server connection string for the message_logs table (every send attempt,
# sent or failed, is recorded here). Requires the Microsoft ODBC Driver for
# SQL Server installed on the machine running the backend/worker.
# Windows Authentication against a local instance:
#   DATABASE_URL=mssql+pyodbc://localhost/TwilioSmsConsole?driver=ODBC+Driver+18+for+SQL+Server&trusted_connection=yes&TrustServerCertificate=yes
# SQL Server login instead of Windows auth:
#   DATABASE_URL=mssql+pyodbc://username:password@host/TwilioSmsConsole?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes
# If unset, falls back to a local SQLite file (message_logs.db) — fine for
# trying things out without a real SQL Server instance.
DATABASE_URL=

# Display name stored on every message log row to identify who triggered the send.
# Change this to the operator's name/username for this console instance.
APP_USER=admin

# Fernet symmetric key used to encrypt PII at rest (phone numbers, emails,
# IP addresses, message bodies). Generate once with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# KEEP THIS SECRET — losing it means existing encrypted rows cannot be decrypted.
ENCRYPTION_KEY=
